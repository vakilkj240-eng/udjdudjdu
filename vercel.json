{
  "version": 2,
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/build",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://yjm.onrender.com/api/:path*"
    },
    {
      "source": "/admin/api/:path*",
      "destination": "https://yjm.onrender.com/admin/api/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
