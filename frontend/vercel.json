{
  "buildCommand": "npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "build",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://udjdudjdu-3.onrender.com/api/:path*"
    },
    {
      "source": "/admin/api/:path*",
      "destination": "https://udjdudjdu-3.onrender.com/admin/api/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
